# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/vitest-test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment variables (secrets — never commit real values)
.env
.env.*
!.env.example

# Sentry build plugin (contains auth token)
.env.sentry-build-plugin

# IDE / editor
.idea/
.vscode/*.code-workspace
*.swp
*.swo
*~

# Turborepo / tooling caches
.turbo/
.eslintcache
.stylelintcache

# OS / editor junk (extra)
*.log
.envrc

# local folder
local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Database
*.db

# storybook
storybook-static
*storybook.log
build-archive.log

# playwright
/test-results/
/playwright-report/
/playwright/.cache/

# Tutorial local (nunca commitar — uso pessoal/equipe offline)
TUTORIAL-SISTEMA.local.md
*.local.md

# Fotos brutas antes do sync (ver docs/scripts/sync-equipment-photos.py)
public/equipamentos/_incoming/

# Uploads locais do painel admin (dev sem Vercel Blob)
public/equipamentos/uploads/*
!public/equipamentos/uploads/.gitkeep
