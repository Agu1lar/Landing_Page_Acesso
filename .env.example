# Copie para .env.local (desenvolvimento) ou configure no Vercel (preview/produção)
# Nunca commite arquivos .env com valores reais.

# --- Obrigatórias (build) ---
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Desenvolvimento local (com npm run dev + PGlite na porta 5433):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/postgres
# Produção / preview (Neon):
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Preview Vercel ---
NEXT_PUBLIC_APP_URL=https://seu-projeto.vercel.app
NEXT_PUBLIC_SENTRY_DISABLED=true

# --- Opcionais ---
# ARCJET_KEY=ajkey_...  (rate limit no POST /api/leads)
# LEADS_NOTIFY_EMAIL=comercial@acessoequipamentos.com.br  (e-mail automático — Sprint 5.7 futuro)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
