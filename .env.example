# Copie para .env.local (desenvolvimento) ou configure no Vercel (preview/produção)
# Nunca commite arquivos .env com valores reais.

# --- Obrigatórias (build) ---
# Preview/local: sk_test_ + pk_test_ (Clerk Development)
# Domínio oficial (Vercel Production): sk_live_ + pk_live_ (Clerk Production) — ver docs/CLERK-ACESSO-ADMIN.md
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Desenvolvimento local (com npm run dev + PGlite na porta 5433):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/postgres
# Produção / preview (Neon):
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Produção (domínio oficial):
# NEXT_PUBLIC_APP_URL=https://acessoequipamentos.com.br
# Preview Vercel (branch/PR):
# NEXT_PUBLIC_APP_URL=https://seu-projeto.vercel.app
NEXT_PUBLIC_SENTRY_DISABLED=true

# --- Opcionais ---
# ARCJET_KEY=ajkey_...  (rate limit no POST /api/leads)
# RESEND_API_KEY=re_...  (https://resend.com — notificação de leads)
# RESEND_FROM_EMAIL=Acesso Equipamentos <onboarding@resend.dev>
# Com onboarding@resend.dev, o Resend só entrega para o e-mail da conta (teste).
# Depois de verificar o domínio, use LEADS_NOTIFY_EMAIL=comercial@...
# LEADS_NOTIFY_EMAIL=seu-email@cadastrado-no-resend.com
# Vercel Blob (upload de fotos no painel admin — produção)
# Ao conectar um Blob store ao projeto, a Vercel injeta BLOB_STORE_ID (e OIDC no deploy).
# BLOB_STORE_ID=store_...  (injetado ao conectar o Blob Public ao projeto)
# BLOB_ACCESS=public
# Sem Blob na Vercel, em desenvolvimento as fotos vão para public/equipamentos/uploads/
# PostHog (opcional — page_view e equipment_view no site marketing)
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Google Analytics 4 (opcional — conversões WhatsApp/lead para Google Ads; ver docs/GOOGLE-ADS-GA4.md)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google One Tap — leads "Google (cookies)" após aceitar analytics (ver docs/GOOGLE-ONE-TAP.md)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
# whatsappOS CRM (opcional — captura server-side do orçamento)
# WHATSAPPOS_API_URL=https://sua-api-crm.exemplo.com
# WHATSAPPOS_WIDGET_KEY=acesso-orcamento-site
