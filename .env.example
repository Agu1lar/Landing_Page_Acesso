# Copie para .env.local (desenvolvimento) ou configure no Vercel (preview/produção)
# Nunca commite arquivos .env com valores reais.

# --- Obrigatórias (build) ---
DASHBOARD_SESSION_SECRET=change-me-to-a-random-string-with-32-chars-min
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Produção (domínio oficial):
# NEXT_PUBLIC_APP_URL=https://acessoequipamentos.com.br
NEXT_PUBLIC_SENTRY_DISABLED=true

# --- Opcionais ---
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Acesso Equipamentos <onboarding@resend.dev>
# LEADS_NOTIFY_EMAIL=comercial@acessoequipamentos.com.br,outro@...
# (comercial@acessoequipamentos.com.br sempre recebe; liste extras separados por vírgula)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=...
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
# Google Ads tag (conta AW-…) — carrega junto do GA4 após consentimento
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-11323862073
# Rótulos de conversão (Ads → Metas → Conversões → tag). Formato: AW-…/rótulo
# NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LEAD=AW-11323862073/xxxxxx
# NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_WHATSAPP=AW-11323862073/yyyyyy
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ChatPro webhook (marque lead quando o cliente responde no WhatsApp)
# Gere um segredo longo e use a mesma URL no painel ChatPro:
# https://acessoequipamentos.com.br/api/webhooks/chatpro?token=SEU_SECRETO
# CHATPRO_WEBHOOK_SECRET=um-segredo-com-pelo-menos-16-caracteres

# API privada para app externo de qualidade comercial / novas campanhas
# Use como: Authorization: Bearer SEU_TOKEN
# INTERNAL_API_SECRET=um-segredo-forte-com-pelo-menos-24-caracteres
